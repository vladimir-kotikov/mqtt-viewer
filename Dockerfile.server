# ──────────────────────────────────────────────
# Stage 0a: Install the wails3 CLI tool
# Cached independently – only re-runs when the pinned version changes.
# ──────────────────────────────────────────────
FROM golang:1.25-alpine AS wails-tool
RUN CGO_ENABLED=0 go install github.com/wailsapp/wails/v3/cmd/wails3@v3.0.0-alpha.74

# ──────────────────────────────────────────────
# Stage 0b: Generate Wails JS/TS bindings
# Only Go source is copied here so frontend edits don't bust this cache.
# ──────────────────────────────────────────────
FROM golang:1.25-alpine AS bindings-generator

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

# Copy only the Go sources needed for binding generation (no frontend/).
COPY *.go ./
COPY backend/ ./backend/
COPY events/ ./events/
COPY wails.json ./

COPY --from=wails-tool /go/bin/wails3 /usr/local/bin/wails3
RUN wails3 generate bindings -clean=true

# ──────────────────────────────────────────────
# Stage 1: Build frontend
# ──────────────────────────────────────────────
FROM node:22-alpine AS frontend-builder

WORKDIR /app/frontend

# Install pnpm
RUN npm install -g pnpm

# Install dependencies (cached layer)
COPY frontend/package.json frontend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Sub-path base URL for Vite build (e.g. "/mqtt-viewer/" or "/")
# Must match the BASE_PATH runtime env var (with trailing slash).
ARG VITE_BASE=/

# Copy source; bindings/mqtt-viewer is overlaid from bindings-generator below
COPY frontend/ ./
# Wails bindings generated from Go source (see bindings-generator stage)
COPY --from=bindings-generator /app/frontend/bindings/mqtt-viewer ./bindings/mqtt-viewer

# Build with base URL
RUN VITE_BASE=${VITE_BASE} pnpm build

# ──────────────────────────────────────────────
# Stage 2: Build Go server binary
# ──────────────────────────────────────────────
FROM golang:1.25-alpine AS go-builder

# patch(1) is needed for the Wails vendor patches
RUN apk add --no-cache patch

WORKDIR /app

# Cache module downloads separately from source (invalidated only when go.mod/go.sum change)
COPY go.mod go.sum ./
RUN go mod download

# Copy full source, then vendor + apply patches (go mod vendor needs source files)
COPY . .
COPY patches/ ./patches/
COPY scripts/apply-patches.sh ./scripts/apply-patches.sh
RUN chmod +x scripts/apply-patches.sh && ./scripts/apply-patches.sh

# Overwrite frontend/dist with the freshly built frontend
COPY --from=frontend-builder /app/frontend/dist ./frontend/dist

# Cross-compile for linux/amd64, no CGO (glebarez/sqlite is pure-Go)
RUN GOOS=linux GOARCH=amd64 CGO_ENABLED=0 \
    go build -mod=vendor -tags server \
    -ldflags="-s -w -X mqtt-viewer/backend/env.Version=0.0.0-docker" \
    -o /server .

# ──────────────────────────────────────────────
# Stage 3: Minimal runtime image
# ──────────────────────────────────────────────
FROM alpine:3.20

RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=go-builder /server ./server

# Create the data mount point with open permissions so the app can bootstrap
# its own directory structure (db, logs, etc.) regardless of which UID/GID
# the container runs as. Set the runtime user via `user:` in docker-compose.
RUN mkdir -p /app/data && chmod 777 /app/data
ENV MQTT_VIEWER_DATA_DIR=/app/data
VOLUME ["/app/data"]

# Bind to all interfaces so the container is reachable from outside
ENV WAILS_SERVER_HOST=0.0.0.0
ENV WAILS_SERVER_PORT=8080

# Optional sub-path when running behind a reverse proxy.
# Must match the VITE_BASE build arg (without trailing slash).
# Examples: BASE_PATH=/mqtt-viewer  or leave empty for root.
ENV BASE_PATH=

EXPOSE 8080

ENTRYPOINT ["./server"]
