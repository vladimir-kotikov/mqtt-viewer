+// normalizeBasePath cleans a base path value from an env var.
+// Returns a string that starts with "/" and has no trailing slash,
+// or "" if the input is empty / "/".
+func normalizeBasePath(s string) string {
+	s = strings.TrimSpace(s)
+	if s == "" || s == "/" {
+		return ""
+	}
+	if !strings.HasPrefix(s, "/") {
+		s = "/" + s
+	}
+	return strings.TrimRight(s, "/")
+}
